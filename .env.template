# =============================================================================
# OIL AMOR — Environment Configuration Template
# =============================================================================
# Copy this file to .env.local and fill in all required values.
# DO NOT commit .env.local to version control.
# =============================================================================

# =============================================================================
# APP CONFIGURATION
# =============================================================================

# Environment: development | staging | production
NEXT_PUBLIC_APP_ENV=development

# Site URL (used for redirects and webhooks)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/oilamor

# =============================================================================
# REDIS (UPSTASH) CONFIGURATION
# =============================================================================

# Redis REST URL from Upstash console
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io

# Redis REST token from Upstash console
UPSTASH_REDIS_REST_TOKEN=

# Redis host for rewards system (fallback to Upstash if not set)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# =============================================================================
# SANITY CONFIGURATION
# =============================================================================

# Project ID from sanity.io/manage
NEXT_PUBLIC_SANITY_PROJECT_ID=

# Dataset name (development, staging, or production)
NEXT_PUBLIC_SANITY_DATASET=development

# API token with read + write permissions
# Create in sanity.io/manage > API > Tokens
SANITY_API_TOKEN=

# Studio URL
NEXT_PUBLIC_SANITY_STUDIO_URL=http://localhost:3333

# =============================================================================
# AUSTRALIA POST CONFIGURATION
# =============================================================================

# API key from Australia Post developer portal
AUSPOST_API_KEY=

# API secret from Australia Post developer portal
AUSPOST_API_SECRET=

# Account number (optional, for negotiated rates)
AUSPOST_ACCOUNT_NUMBER=

# =============================================================================
# PAYMENT CONFIGURATION
# =============================================================================

# Stripe publishable key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Stripe secret key
STRIPE_SECRET_KEY=sk_test_...

# Stripe webhook secret
STRIPE_WEBHOOK_SECRET=whsec_...

# PayPal client ID
NEXT_PUBLIC_PAYPAL_CLIENT_ID=

# PayPal client secret
PAYPAL_CLIENT_SECRET=

# PayPal environment: sandbox | live
PAYPAL_ENVIRONMENT=sandbox

# =============================================================================
# AUTHENTICATION (Optional - for customer accounts)
# =============================================================================

# NextAuth.js secret (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET=

# NextAuth.js URL
NEXTAUTH_URL=http://localhost:3000

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# =============================================================================
# MONITORING & ANALYTICS
# =============================================================================

# Sentry DSN for error tracking
SENTRY_DSN=

# Sentry environment
SENTRY_ENVIRONMENT=development

# Vercel Analytics ID (auto-populated on Vercel)
VERCEL_ANALYTICS_ID=

# Google Analytics ID (optional)
NEXT_PUBLIC_GA_ID=

# Facebook Pixel ID (optional)
NEXT_PUBLIC_FB_PIXEL_ID=

# =============================================================================
# FEATURE FLAGS
# =============================================================================

# Enable/disable refills system
FEATURE_REFILLS=true

# Enable/disable synergies guide
FEATURE_SYNERGIES=true

# Enable/disable Australia Post shipping
FEATURE_AUSPOST_SHIPPING=true

# Enable/disable international shipping
FEATURE_INTERNATIONAL_SHIPPING=false

# Enable/disable pre-orders
FEATURE_PREORDERS=false

# =============================================================================
# EMAIL CONFIGURATION (Optional)
# =============================================================================

# SendGrid API key
SENDGRID_API_KEY=

# From email address
EMAIL_FROM=noreply@oilamor.com

# Support email
EMAIL_SUPPORT=support@oilamor.com

# Admin notification email (order alerts, contact forms)
ADMIN_EMAIL=official.oilamor@gmail.com

# =============================================================================
# ADVANCED CONFIGURATION
# =============================================================================

# Cache TTL in seconds (default: 300 = 5 minutes)
CACHE_TTL_SECONDS=300

# Maximum cart items
MAX_CART_ITEMS=50

# Session timeout in hours
SESSION_TIMEOUT_HOURS=24

# Rate limit requests per minute
RATE_LIMIT_PER_MINUTE=60
