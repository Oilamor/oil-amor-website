#!/bin/sh
# Pre-commit hook: Scan for potential secrets
# Install: cp scripts/hooks/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit

echo "🔒 Scanning for secrets..."

# Check staged files (skip this hook file and docs)
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -v -E "^(scripts/hooks/pre-commit|SECURITY\.md)$")

if [ -z "$STAGED_FILES" ]; then
  exit 0
fi

# Patterns to block (basic regex, no alternation in -G)
FOUND=0

# Stripe webhook secrets
MATCHES=$(git diff --cached --diff-filter=ACM -G "whsec_[a-zA-Z0-9]" | head -20)
if [ -n "$MATCHES" ]; then
  echo ""
  echo "❌ BLOCKED: Potential Stripe webhook secret detected"
  echo "$MATCHES"
  FOUND=1
fi

# Stripe secret keys
MATCHES=$(git diff --cached --diff-filter=ACM -G "sk_live_[a-zA-Z0-9]" | head -20)
if [ -n "$MATCHES" ]; then
  echo ""
  echo "❌ BLOCKED: Potential Stripe live secret key detected"
  echo "$MATCHES"
  FOUND=1
fi

# AWS keys
MATCHES=$(git diff --cached --diff-filter=ACM -G "AKIA[0-9A-Z]" | head -20)
if [ -n "$MATCHES" ]; then
  echo ""
  echo "❌ BLOCKED: Potential AWS access key detected"
  echo "$MATCHES"
  FOUND=1
fi

# GitHub tokens
MATCHES=$(git diff --cached --diff-filter=ACM -G "ghp_[a-zA-Z0-9]" | head -20)
if [ -n "$MATCHES" ]; then
  echo ""
  echo "❌ BLOCKED: Potential GitHub token detected"
  echo "$MATCHES"
  FOUND=1
fi

# Private keys
MATCHES=$(git diff --cached --diff-filter=ACM -G "BEGIN PRIVATE KEY" | head -20)
if [ -n "$MATCHES" ]; then
  echo ""
  echo "❌ BLOCKED: Potential private key detected"
  echo "$MATCHES"
  FOUND=1
fi

if [ "$FOUND" -eq 1 ]; then
  echo ""
  echo "🚨 Commit blocked. Secrets must not be committed to git."
  echo "If this is a false positive: git commit --no-verify"
  echo ""
  exit 1
fi

echo "✅ No secrets detected."
exit 0
